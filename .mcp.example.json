{
  "mcpServers": {
    "gmail": {
      "command": "node",
      "args": ["./src/mcp-gmail/index.js"],
      "env": {
        "GMAIL_CLIENT_ID": "YOUR_GOOGLE_CLIENT_ID",
        "GMAIL_CLIENT_SECRET": "YOUR_GOOGLE_CLIENT_SECRET",
        "GMAIL_REFRESH_TOKEN": "YOUR_GMAIL_REFRESH_TOKEN"
      }
    },
    "google-calendar": {
      "command": "npx",
      "args": ["-y", "@cocal/google-calendar-mcp"],
      "env": {
        "GOOGLE_CLIENT_ID": "YOUR_GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET": "YOUR_GOOGLE_CLIENT_SECRET",
        "GOOGLE_REFRESH_TOKEN": "YOUR_CALENDAR_REFRESH_TOKEN"
      }
    },
    "imap": {
      "command": "node",
      "args": ["./src/mcp-imap/index.js"],
      "env": {
        "IMAP_HOST": "mail.yourdomain.com",
        "IMAP_PORT": "993",
        "IMAP_USER": "you@yourdomain.com",
        "IMAP_PASSWORD": "YOUR_IMAP_PASSWORD",
        "IMAP_TLS": "true"
      }
    },
    "sncf": {
      "comment": "French train schedules — no API key required",
      "command": "node",
      "args": ["./src/mcp-sncf/index.js"]
    }
  }
}
