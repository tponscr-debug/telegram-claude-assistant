{
  "mcpServers": {
    "gmail": {
      "command": "node",
      "args": ["./mcp-gmail/index.js"]
    },
    "google-calendar": {
      "command": "npx",
      "args": ["-y", "@cocal/google-calendar-mcp"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/home/yourname/.config/google-calendar-mcp/gcp-oauth.keys.json",
        "GOOGLE_CALENDAR_MCP_TOKEN_PATH": "/home/yourname/.config/google-calendar-mcp/tokens.json"
      }
    },
    "imap": {
      "command": "node",
      "args": ["./mcp-imap/index.js"],
      "env": {
        "IMAP_HOST": "mail.youromain.com",
        "IMAP_PORT": "993",
        "IMAP_USER": "you@yourdomain.com",
        "IMAP_PASSWORD": "YOUR_IMAP_PASSWORD",
        "IMAP_TLS": "true"
      }
    },
    "sncf": {
      "command": "node",
      "args": ["./mcp-sncf/index.js"],
      "env": {
        "SNCF_API_KEY": "YOUR_SNCF_API_KEY"
      }
    },
    "airbnb": {
      "command": "node",
      "args": ["./node_modules/@openbnb/mcp-server-airbnb/dist/index.js"]
    }
  }
}
