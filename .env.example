# Telegram
TELEGRAM_TOKEN=          # Get from @BotFather on Telegram
YOUR_CHAT_ID=            # Your Telegram user ID (get from @userinfobot)

# Google / Gemini (for voice transcription)
GEMINI_API_KEY=          # Get from Google AI Studio: aistudio.google.com

# Project
ASSISTANT_DIR=           # Absolute path to this project directory
                         # e.g. /home/yourname/Projects/assistant

# Scheduler
SCHEDULER_TIMEZONE=Europe/Paris   # Change to your timezone
                                   # List: en.wikipedia.org/wiki/List_of_tz_database_time_zones
